{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sab.local/schemas/sab.standing_lease.v1.schema.json",
  "title": "SAB Standing Lease v1",
  "description": "Scoped, expiring, revocable reliance lease issued only after witnessed challenge.",
  "type": "object",
  "required": [
    "schema",
    "standing_id",
    "subject_seed_id",
    "subject_claim_id",
    "scope",
    "purpose",
    "allowed_reliance",
    "forbidden_reliance",
    "expiry",
    "revoker",
    "challenge_path",
    "challenge_summary",
    "witness_quorum",
    "status",
    "revalidation_policy",
    "machine_readable_evidence_bundle",
    "standing_basis",
    "issued_at",
    "issued_by",
    "policy_hash",
    "signature"
  ],
  "properties": {
    "schema": { "const": "sab.standing_lease.v1" },
    "standing_id": {
      "type": "string",
      "pattern": "^sab_standing_[A-Za-z0-9_.:-]{3,}$"
    },
    "subject_seed_id": {
      "type": "string",
      "pattern": "^sab_seed_[A-Za-z0-9_.:-]{3,}$"
    },
    "subject_claim_id": {
      "type": "string",
      "pattern": "^sab_claim_[A-Za-z0-9_.:-]{3,}$"
    },
    "scope": { "type": "string", "minLength": 5 },
    "purpose": { "type": "string", "minLength": 5 },
    "allowed_reliance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "forbidden_reliance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "expiry": { "type": "string", "format": "date-time" },
    "revoker": { "type": "string", "minLength": 3 },
    "challenge_path": {
      "type": "string",
      "pattern": "^(https?://|/)[^\\s]+$"
    },
    "challenge_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["challenge_id", "resolution", "witness_event_id"],
        "properties": {
          "challenge_id": {
            "type": "string",
            "pattern": "^sab_challenge_[A-Za-z0-9_.:-]{3,}$"
          },
          "resolution": {
            "type": "string",
            "enum": ["survived", "narrowed", "corrected", "rejected"]
          },
          "witness_event_id": {
            "type": "string",
            "pattern": "^sab_witness_[A-Za-z0-9_.:-]{3,}$"
          }
        },
        "additionalProperties": false
      }
    },
    "witness_quorum": {
      "type": "object",
      "required": ["minimum_witnesses", "witnesses", "diversity_policy"],
      "properties": {
        "minimum_witnesses": { "type": "integer", "minimum": 1 },
        "witnesses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "witness_event_id",
              "witness_identity",
              "role",
              "operator_backing_ref"
            ],
            "properties": {
              "witness_event_id": {
                "type": "string",
                "pattern": "^sab_witness_[A-Za-z0-9_.:-]{3,}$"
              },
              "witness_identity": {
                "type": "string",
                "pattern": "^sab_identity_[A-Za-z0-9_.:-]{3,}$"
              },
              "role": { "type": "string", "minLength": 3 },
              "operator_backing_ref": { "type": "string", "minLength": 3 }
            },
            "additionalProperties": false
          }
        },
        "diversity_policy": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": [
        "provisional",
        "active",
        "challenged",
        "revoked",
        "expired",
        "superseded",
        "canon",
        "compost"
      ]
    },
    "revalidation_policy": { "type": "string", "minLength": 5 },
    "machine_readable_evidence_bundle": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ref", "kind", "privacy_class"],
        "properties": {
          "ref": { "type": "string", "minLength": 3 },
          "kind": {
            "type": "string",
            "enum": ["source", "test", "trace", "receipt", "proof", "review", "attestation", "witness_event"]
          },
          "digest": {
            "type": "string",
            "pattern": "^(sha256:)?[a-f0-9]{64}$"
          },
          "privacy_class": {
            "type": "string",
            "enum": ["public", "redacted_public", "private_pointer"]
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "standing_basis": {
      "type": "object",
      "required": [
        "basis_type",
        "challenge_event_refs",
        "witness_event_refs",
        "evidence_refs",
        "external_attestation_effect"
      ],
      "properties": {
        "basis_type": {
          "description": "Standing can only come from witnessed challenge, never from identity or external reputation.",
          "const": "witnessed_challenge"
        },
        "challenge_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^sab_challenge_[A-Za-z0-9_.:-]{3,}$"
          }
        },
        "witness_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^sab_witness_[A-Za-z0-9_.:-]{3,}$"
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "external_attestation_effect": { "const": "none" }
      },
      "additionalProperties": false
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "issued_by": { "type": "string", "minLength": 3 },
    "policy_hash": {
      "type": "string",
      "pattern": "^(sha256:)?[a-f0-9]{64}$"
    },
    "signature": {
      "type": "object",
      "required": [
        "alg",
        "signer",
        "signature",
        "canonicalization",
        "signed_payload"
      ],
      "properties": {
        "alg": { "const": "ed25519" },
        "signer": { "type": "string", "minLength": 3 },
        "signature": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        },
        "canonicalization": { "const": "json-sort-keys-compact-v1" },
        "signed_payload": {
          "type": "object",
          "required": [
            "kind",
            "standing_id",
            "subject_seed_id",
            "subject_claim_id",
            "payload_hash",
            "issued_at"
          ],
          "properties": {
            "kind": { "const": "sab_standing_lease" },
            "standing_id": {
              "type": "string",
              "pattern": "^sab_standing_[A-Za-z0-9_.:-]{3,}$"
            },
            "subject_seed_id": {
              "type": "string",
              "pattern": "^sab_seed_[A-Za-z0-9_.:-]{3,}$"
            },
            "subject_claim_id": {
              "type": "string",
              "pattern": "^sab_claim_[A-Za-z0-9_.:-]{3,}$"
            },
            "payload_hash": {
              "type": "string",
              "pattern": "^(sha256:)?[a-f0-9]{64}$"
            },
            "issued_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
