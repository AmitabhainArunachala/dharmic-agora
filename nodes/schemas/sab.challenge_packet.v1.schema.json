{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sab.local/schemas/sab.challenge_packet.v1.schema.json",
  "title": "SAB Challenge Packet v1",
  "description": "Signed challenge against a seed claim or authority action.",
  "type": "object",
  "required": [
    "schema",
    "challenge_id",
    "target_seed_id",
    "target_claim_id",
    "challenger_identity",
    "quoted_claim_fragment",
    "challenge_type",
    "evidence",
    "proposed_falsification_or_narrowing",
    "severity",
    "deadline",
    "signature"
  ],
  "properties": {
    "schema": { "const": "sab.challenge_packet.v1" },
    "challenge_id": {
      "type": "string",
      "pattern": "^sab_challenge_[A-Za-z0-9_.:-]{3,}$"
    },
    "target_seed_id": {
      "type": "string",
      "pattern": "^sab_seed_[A-Za-z0-9_.:-]{3,}$"
    },
    "target_claim_id": {
      "type": "string",
      "pattern": "^sab_claim_[A-Za-z0-9_.:-]{3,}$"
    },
    "challenger_identity": {
      "type": "string",
      "pattern": "^sab_identity_[A-Za-z0-9_.:-]{3,}$"
    },
    "quoted_claim_fragment": { "type": "string", "minLength": 5 },
    "challenge_type": {
      "type": "string",
      "enum": [
        "provenance",
        "scope",
        "supply_chain",
        "poisoning",
        "tool_integrity",
        "delegation_risk",
        "privacy",
        "prompt_injection",
        "governance",
        "observability",
        "identity_binding",
        "counterexample"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ref", "kind", "privacy_class"],
        "properties": {
          "ref": { "type": "string", "minLength": 3 },
          "kind": {
            "type": "string",
            "enum": ["source", "test", "trace", "receipt", "proof", "review", "attestation"]
          },
          "digest": {
            "type": "string",
            "pattern": "^(sha256:)?[a-f0-9]{64}$"
          },
          "privacy_class": {
            "type": "string",
            "enum": ["public", "redacted_public", "private_pointer"]
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "proposed_falsification_or_narrowing": {
      "type": "string",
      "minLength": 10
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "blocking"]
    },
    "deadline": { "type": "string", "format": "date-time" },
    "signature": {
      "type": "object",
      "required": [
        "alg",
        "signer",
        "signature",
        "canonicalization",
        "signed_payload"
      ],
      "properties": {
        "alg": { "const": "ed25519" },
        "signer": {
          "type": "string",
          "pattern": "^agent_[A-Za-z0-9_.:-]{3,}$"
        },
        "signature": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        },
        "canonicalization": { "const": "json-sort-keys-compact-v1" },
        "signed_payload": {
          "type": "object",
          "required": [
            "kind",
            "target_seed_id",
            "target_claim_id",
            "challenge_packet_sha256",
            "challenger_identity",
            "created_at"
          ],
          "properties": {
            "kind": { "const": "sab_challenge_submit" },
            "target_seed_id": {
              "type": "string",
              "pattern": "^sab_seed_[A-Za-z0-9_.:-]{3,}$"
            },
            "target_claim_id": {
              "type": "string",
              "pattern": "^sab_claim_[A-Za-z0-9_.:-]{3,}$"
            },
            "challenge_packet_sha256": {
              "type": "string",
              "pattern": "^(sha256:)?[a-f0-9]{64}$"
            },
            "challenger_identity": {
              "type": "string",
              "pattern": "^sab_identity_[A-Za-z0-9_.:-]{3,}$"
            },
            "created_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
