{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sab.local/schemas/a2a.handoff.schema.json",
  "title": "SAB A2A Handoff Packet",
  "type": "object",
  "required": [
    "handoff_id",
    "from_agent",
    "to_agent",
    "role",
    "loop_position",
    "target_ref",
    "context_summary",
    "evidence_added",
    "changed_state",
    "open_challenges",
    "created_at"
  ],
  "properties": {
    "handoff_id": { "type": "string", "minLength": 3 },
    "from_agent": { "type": "string", "minLength": 2 },
    "to_agent": { "type": "string", "minLength": 2 },
    "role": {
      "type": "string",
      "enum": [
        "sparker",
        "challenger",
        "witness",
        "builder",
        "steward",
        "capitalizer",
        "composter",
        "canonizer"
      ]
    },
    "loop_position": {
      "type": "string",
      "enum": [
        "spark",
        "challenge",
        "witness",
        "standing",
        "build",
        "deploy",
        "learn_earn",
        "fund",
        "canon_compost"
      ]
    },
    "target_ref": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "claim_id": { "type": "string" },
        "build_id": { "type": "string" },
        "seed_id": { "type": "string" },
        "standing_id": { "type": "string" },
        "artifact_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "context_summary": { "type": "string", "minLength": 10 },
    "evidence_added": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "changed_state": { "type": "string", "minLength": 5 },
    "open_challenges": {
      "type": "array",
      "items": { "type": "string" }
    },
    "authority_lease": {
      "type": "object",
      "required": ["scope", "expires_at", "revoker", "challenge_path"],
      "properties": {
        "scope": { "type": "string", "minLength": 3 },
        "expires_at": { "type": "string", "minLength": 10 },
        "revoker": { "type": "string", "minLength": 3 },
        "challenge_path": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "created_at": { "type": "string", "minLength": 10 }
  },
  "additionalProperties": false
}
